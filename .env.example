# 0. Owner config (Email của Admin cao nhất)
OWNER_EMAIL=your_email@gmail.com

# 1. Google OAuth (Login)
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
SESSION_SECRET=a_very_long_random_secret_string

# 2. Ngrok/Domain (Public URL)
WEBHOOK_URL=https://your-ngrok.app/webhook

# 3. Facebook App (Platform level)
FB_APP_SECRET=your_facebook_app_secret
FB_VERIFY_TOKEN=ai4all_verify_2026

# 4. Google Gemini API (AI Provider)
GEMINI_API_KEY=your_gemini_api_key

# 5. Server settings
PORT=3000
MAX_FILE_SIZE=10485760 # 10MB
TRIAL_TOKEN_LIMIT=5000
BASIC_TOKEN_LIMIT=50000

# 6. Default AI config
DEFAULT_AI_MODEL=gemini-2.5-flash
SYSTEM_PROMPT="Bạn là nhân viên lễ tân ưu tú. Hãy trả lời khách hàng một cách lịch sự, thân thiện và chính xác dựa trên tài liệu."
