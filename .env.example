# Facebook Messenger
FB_PAGE_ACCESS_TOKEN=your_page_access_token_here
FB_VERIFY_TOKEN=hotel_bot_verify_2024
FB_APP_SECRET=your_app_secret_here

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# Server
PORT=3000

# System Prompt (default)
SYSTEM_PROMPT=Bạn là nhân viên lễ tân khách sạn chuyên nghiệp. Hãy trả lời khách hàng một cách lịch sự, thân thiện và hữu ích. Sử dụng thông tin từ tài liệu được cung cấp để trả lời chính xác. Nếu không biết câu trả lời, hãy nói rằng bạn sẽ chuyển câu hỏi đến bộ phận phù hợp.
